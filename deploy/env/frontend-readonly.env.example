# 复制为 deploy/env/frontend-readonly.env 后再启动
#
# 设计目标:
# - 仅替换前端，不替换正式后端
# - 所有浏览与调样式流量先过只读代理
# - 代理只允许安全读请求，阻断登录、登出、绑定、写入、回调等有副作用入口

READONLY_PROXY_PORT=3300

# 默认指向本机正式服务
READONLY_UPSTREAM=http://host.docker.internal:3000

# 必填: 只读代理模板文件绝对路径
# macOS:
# READONLY_PROXY_TEMPLATE_PATH=/Volumes/Work/code/new-api/deploy/nginx/frontend-readonly.conf.template
# Linux:
# READONLY_PROXY_TEMPLATE_PATH=/srv/new-api/deploy/nginx/frontend-readonly.conf.template
# Windows:
# READONLY_PROXY_TEMPLATE_PATH=C:/new-api/deploy/nginx/frontend-readonly.conf.template
# WSL:
# READONLY_PROXY_TEMPLATE_PATH=/home/<user>/new-api/deploy/nginx/frontend-readonly.conf.template
READONLY_PROXY_TEMPLATE_PATH=

# 前端本地开发建议搭配:
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3300
# VITE_REACT_APP_READONLY_MODE=true
