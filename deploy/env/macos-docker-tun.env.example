# Copy to deploy/env/macos-docker-tun.env before use.
#
# This optional mode is for macOS Docker Desktop hosts that run a TUN proxy
# such as FlClash or Clash and observe wrong client IPs in new-api logs.
#
# It keeps the Compose service reachable only from the macOS host loopback.
# A host-side Caddy process should listen on the LAN entry port and proxy to
# this loopback endpoint. Do not run that Caddy entry proxy inside Docker for
# this IP-fix mode.

# Compose service name to recreate. Keep the default for this repository.
COMPOSE_SERVICE=new-api

# Public LAN entry served by host-side Caddy.
NEW_API_LAN_PROXY_PORT=3000

# Host loopback port published by Docker for the service.
NEW_API_LOOPBACK_PORT=13000

# Container port exposed by the service.
NEW_API_CONTAINER_PORT=3000

# Health path used for preflight and post-apply checks.
NEW_API_HEALTH_PATH=/api/status

# Direct Docker published port used during rollback.
NEW_API_DEFAULT_PORT_MAPPING=3000:3000

# By default, --apply refuses to recreate new-api while port 3000 has
# established connections. Set to 1 only when you accept interrupting them.
NEW_API_ALLOW_ACTIVE_REQUESTS=0

# Optional grep -E pattern for the wrong TUN source IP seen in service logs.
# Example: NEW_API_ABNORMAL_TUN_IP_REGEX='171\.80\.0\.108'
NEW_API_ABNORMAL_TUN_IP_REGEX=

# Keep this in sync with the three port variables above.
NEW_API_PORT_MAPPING=127.0.0.1:13000:3000
