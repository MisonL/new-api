# 复制为 deploy/env/dev-isolated.env 后再启动
#
# 设计目标:
# - 与正式 new-api、正式 PostgreSQL、正式 Redis 完全隔离
# - 独立端口、独立数据库目录、独立应用数据目录、独立日志目录

DEV_NEW_API_IMAGE=new-api-local:dev
DEV_NEW_API_PORT=3001
DEV_POSTGRES_PORT=5433
DEV_REDIS_PORT=6380

# 必填: 宿主机绝对路径
# macOS:
# DEV_NEW_API_DATA_DIR=/Volumes/Work/code/new-api/.dev-docker/runtime/isolated/data
# DEV_NEW_API_LOG_DIR=/Volumes/Work/code/new-api/.dev-docker/runtime/isolated/logs
# DEV_POSTGRES_DATA_DIR=/Volumes/Work/code/new-api/.dev-docker/runtime/isolated/postgres
#
# Linux:
# DEV_NEW_API_DATA_DIR=/srv/new-api/dev/data
# DEV_NEW_API_LOG_DIR=/srv/new-api/dev/logs
# DEV_POSTGRES_DATA_DIR=/srv/new-api/dev/postgres
#
# Windows:
# DEV_NEW_API_DATA_DIR=C:/new-api/dev/data
# DEV_NEW_API_LOG_DIR=C:/new-api/dev/logs
# DEV_POSTGRES_DATA_DIR=C:/new-api/dev/postgres
#
# WSL:
# DEV_NEW_API_DATA_DIR=/home/<user>/new-api/.dev-docker/runtime/isolated/data
# DEV_NEW_API_LOG_DIR=/home/<user>/new-api/.dev-docker/runtime/isolated/logs
# DEV_POSTGRES_DATA_DIR=/home/<user>/new-api/.dev-docker/runtime/isolated/postgres
DEV_NEW_API_DATA_DIR=
DEV_NEW_API_LOG_DIR=
DEV_POSTGRES_DATA_DIR=

# 必填: 不得复用正式环境 secret
DEV_SESSION_SECRET=
DEV_CRYPTO_SECRET=

DEV_POSTGRES_USER=root
DEV_POSTGRES_PASSWORD=123456
DEV_POSTGRES_DB=new-api-dev
DEV_SQL_DSN=postgresql://root:123456@postgres:5432/new-api-dev
DEV_REDIS_CONN_STRING=redis://redis:6379/0
DEV_TZ=Asia/Shanghai
DEV_ERROR_LOG_ENABLED=true
DEV_BATCH_UPDATE_ENABLED=true
